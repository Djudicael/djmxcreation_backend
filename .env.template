# ── PostgreSQL ──────────────────────────────────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=portfolio
PG_USER=postgres
PG_PASSWORD=
PG_APP_MAX_CON=5

# ── Object storage (RustFS / S3-compatible) ─────────────────────────────────
# Point STORAGE_ENDPOINT at your RustFS (or any S3-compatible) server.
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=portfolio

# ── API security ────────────────────────────────────────────────────────────
USERNAME_APP=
PASSWORD_APP=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8081

# ── Logging ──────────────────────────────────────────────────────────────────
# Examples: "info", "debug", "info,repository=debug,app_service=debug"
RUST_LOG=info
