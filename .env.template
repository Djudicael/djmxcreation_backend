# ── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/portfolio

# ── Object storage (RustFS / S3-compatible) ─────────────────────────────────
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=portfolio

# ── API security ────────────────────────────────────────────────────────────
USERNAME_APP=
PASSWORD_APP=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8081

# ── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info
